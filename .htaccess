 Options -Indexes
Options -MultiViews

RewriteEngine On

# Força HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Bloqueia acesso direto ao .env
<Files ".env">
    Order allow,deny
    Deny from all
</Files>

# Bloqueia acesso à pasta config
<FilesMatch "^config/">
    Order allow,deny
    Deny from all
</FilesMatch>

# Bloqueia acesso à pasta agents
<FilesMatch "^agents/">
    Order allow,deny
    Deny from all
</FilesMatch>

# Bloqueia acesso à pasta sql
<FilesMatch "^sql/">
    Order allow,deny
    Deny from all
</FilesMatch>

# Redireciona raiz para login se não autenticado
RewriteRule ^$ /index.php [L]

# Remove .php da URL (opcional)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+)$ /$1.php [L]

# Headers de segurança
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Cache de assets estáticos
<FilesMatch "\.(css|js|png|jpg|gif|ico|woff2)$">
    Header set Cache-Control "max-age=2592000, public"
</FilesMatch>